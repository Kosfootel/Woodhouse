# CODEOWNERS

# This file defines code ownership for automatic reviewer assignment
# Pattern matching follows gitignore-style patterns

# Global fallback - require review from at least one agent
* @Kosfootel @woodhouse-ai @ray-ai @liz-ai

# ============================================================
# AGENT-SPECIFIC OWNERSHIP
# ============================================================

# Woodhouse owns Woodhouse-specific content
.github/agents/woodhouse/ @woodhouse-ai
memory/woodhouse/ @woodhouse-ai
docs/woodhouse/ @woodhouse-ai

# Ray owns Ray-specific content
.github/agents/ray/ @ray-ai
memory/ray/ @ray-ai
docs/ray/ @ray-ai
protocols/ @ray-ai

# Liz owns Liz-specific content
.github/agents/liz/ @liz-ai
memory/liz/ @liz-ai
docs/liz/ @liz-ai

# ============================================================
# SHARED STANDARDS (All agents must review)
# ============================================================

# Global templates - require consensus
templates/ @woodhouse-ai @ray-ai @liz-ai
standards/ @woodhouse-ai @ray-ai @liz-ai
.github/ISSUE_TEMPLATE/ @woodhouse-ai @ray-ai @liz-ai
.github/pull_request_template.md @woodhouse-ai @ray-ai @liz-ai
.github/CODEOWNERS @woodhouse-ai @ray-ai @liz-ai

# Shared protocols - all agents affected
protocols/ @woodhouse-ai @ray-ai @liz-ai
protocols/a2a/ @ray-ai @woodhouse-ai @liz-ai

# Shared workflows - all agents affected
.github/workflows/sync-shared-content.yml @woodhouse-ai @ray-ai @liz-ai

# ============================================================
# INFRASTRUCTURE & WORKFLOWS
# ============================================================

# Core workflows - require Woodhouse review
.github/workflows/ @woodhouse-ai

# Privacy and security - require all agents
.github/workflows/privacy-scan.yml @woodhouse-ai @ray-ai @liz-ai
.github/SECURITY.md @woodhouse-ai @ray-ai @liz-ai

# Documentation standards - require Liz review
CONTRIBUTING.md @liz-ai @woodhouse-ai
README.md @liz-ai

# ============================================================
# COMPLIANCE & GOVERNANCE
# ============================================================

# Compliance log - requires Erik review
COMPLIANCE_LOG.md @Kosfootel

# Decision records - require all agents
rfcs/ @woodhouse-ai @ray-ai @liz-ai
adr/ @woodhouse-ai @ray-ai @liz-ai
postmortems/ @woodhouse-ai @ray-ai @liz-ai

# ============================================================
# PROJECT-SPECIFIC
# ============================================================

# Incubate projects - project lead owns
projects/incubate/*/ @woodhouse-ai

# HockeyOps projects - require Erik approval
projects/hockeyops*/ @Kosfootel

